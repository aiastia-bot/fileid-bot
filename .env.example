# ===== 数据库配置 =====
# 数据库类型：sqlite（默认）或 mysql
DB_TYPE=sqlite
# 数据库连接 URL（仅 DB_TYPE=mysql 时需要）
# 以下格式均可（程序会自动补全驱动前缀）:
#   user:password@localhost:3306/fileid_bot
#   mysql://user:password@localhost:3306/fileid_bot
#   mysql+aiomysql://user:password@localhost:3306/fileid_bot
DATABASE_URL=
# SQLite 数据库文件路径（默认 ./data/fileid.db）
DB_PATH=./data/fileid.db

# 主Bot Token（管理Bot，用于用户注册/管理自己的Bot）
BOT_TOKEN=你的主Bot_Token

# 管理员 Telegram ID（逗号分隔，可查看平台统计）
ADMIN_IDS=123456789

# 每个用户最多添加的Bot数量（默认1）
MAX_BOTS_PER_USER=1

# 代码前缀（留空则使用 Bot 用户名）
CODE_PREFIX=

# 用户访问模式：默认黑名单模式（blacklist）
# 黑名单用户将被禁止使用主Bot的所有功能
# 管理员使用 /blacklist 命令管理黑名单
# - /blacklist add <用户ID> [原因]  添加到黑名单
# - /blacklist del <用户ID>         从黑名单移除
# - /blacklist list                 查看黑名单
# - /blacklist check <用户ID>       检查用户状态

# ===== 发送限速与重试配置 =====
# 发送失败重试次数（默认3次）
SEND_RETRY_COUNT=3
# 重试基础延迟秒数，实际延迟 = delay × 2^重试次数（默认2秒）
SEND_RETRY_DELAY=2.0
# 每组发送之间的延迟秒数（默认1秒）
SEND_BATCH_DELAY=1.0
# 单个文件发送之间的延迟秒数（默认0.5秒）
SEND_INDIVIDUAL_DELAY=0.5
# 单次请求最大发送文件数（默认30），超过则自动分批
SEND_MAX_FILES_PER_REQUEST=30
# 每 Bot 最小发送间隔秒数（默认1秒），队列消费者使用
SEND_MIN_INTERVAL=1.0
# Telegram API 读取超时秒数（默认60秒）
API_READ_TIMEOUT=60.0
# Telegram API 写入超时秒数（默认60秒）
API_WRITE_TIMEOUT=60.0
# Telegram API 连接超时秒数（默认30秒）
API_CONNECT_TIMEOUT=30.0

# ===== Webhook 模式配置 =====
# Bot 运行模式：polling（默认）或 webhook
BOT_MODE=polling
# Webhook 外部域名（不含 https://），如 bots.example.com
WEBHOOK_HOST=
# Webhook 本地监听端口（默认8080）
WEBHOOK_PORT=8080
# Webhook URL 基路径（默认 /webhook）
WEBHOOK_PATH=/webhook
# Webhook secret token（可选，用于验证请求来源）
WEBHOOK_SECRET=

# 群组支持（默认 false，仅允许私聊）
ALLOW_GROUP=false

# ===== 日志配置 =====
# 日志级别：DEBUG（全部）、INFO（一般信息）、WARNING（警告+错误，推荐日常）、ERROR（仅错误）
# 日常运行推荐 WARNING，排查问题时改为 INFO 或 DEBUG
LOG_LEVEL=WARNING

# ===== 分布式架构配置 =====
# 节点角色：standalone（单机，默认）/ master（主控节点）/ worker（工作节点）
# standalone: 单机运行，和之前一样
# master: 主控节点，运行主Bot + 调度器，分配Bot到Worker
# worker: 工作节点，只运行用户Bot，接收Master指令
ROLE=standalone

# Master 节点地址（Worker 模式必填，如 http://master:8080 或 https://1.1.1.1:8080）
MASTER_URL=

# Worker 节点标识（每个 Worker 唯一，如 worker-1, worker-2）
NODE_ID=local

# 内部通信密钥（Master 和 Worker 必须一致，用于 API 鉴权）
WORKER_SECRET=

# Worker 内部 API 端口（默认 8081）
WORKER_PORT=8081

# 每个 Worker 最大 Bot 数量（默认 100）
MAX_BOTS_PER_WORKER=100

# Worker 健康检查间隔秒数（默认 60）
HEALTH_CHECK_INTERVAL=60

# Worker 自身对外 Webhook 域名（Worker 模式下需要配置，如 node1.example.com）
WORKER_WEBHOOK_HOST=

# ===== MTProto 检测配置（可选） =====
# 是否开启 MTProto 异常行为检测（默认 false）
# 检测原理：基于消息ID连续性分析，当有人通过 MTProto 使用 Bot Token 时，
# 其回复会占用 message_id 序号，导致用户消息 ID 出现跳跃。
# 累积 3 次可疑跳跃后自动停止该 Bot 并通知管理员
# 管理命令：/mtproto on/off/threshold
MTPROTO_DETECTION=false

# ===== Redis 配置（可选） =====
# 不配置时使用内存降级方案（单节点可用，多节点建议配置）
REDIS_URL=
# 限流窗口秒数（默认60）
RATE_LIMIT_WINDOW=60
# 窗口内最大请求数（默认30）
RATE_LIMIT_MAX=30
# 限流排队最大等待秒数（默认10）
RATE_LIMIT_MAX_WAIT=10
# 单次 RetryAfter 最大等待秒数（默认30），超过则放弃让 Telegram 重试（防止 499）
RETRY_AFTER_MAX_WAIT=30.0
