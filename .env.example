# 主Bot Token（管理Bot，用于用户注册/管理自己的Bot）
BOT_TOKEN=你的主Bot_Token

# 管理员 Telegram ID（逗号分隔，可查看平台统计）
ADMIN_IDS=123456789

# 每个用户最多添加的Bot数量（默认1）
MAX_BOTS_PER_USER=1

# 代码前缀（留空则使用 Bot 用户名）
CODE_PREFIX=

# 用户访问模式：默认黑名单模式（blacklist）
# 黑名单用户将被禁止使用主Bot的所有功能
# 管理员使用 /blacklist 命令管理黑名单
# - /blacklist add <用户ID> [原因]  添加到黑名单
# - /blacklist del <用户ID>         从黑名单移除
# - /blacklist list                 查看黑名单
# - /blacklist check <用户ID>       检查用户状态

# ===== 发送限速与重试配置 =====
# 发送失败重试次数（默认3次）
SEND_RETRY_COUNT=3
# 重试基础延迟秒数，实际延迟 = delay × 2^重试次数（默认2秒）
SEND_RETRY_DELAY=2.0
# 每组发送之间的延迟秒数（默认1秒）
SEND_BATCH_DELAY=1.0
# 单个文件发送之间的延迟秒数（默认0.5秒）
SEND_INDIVIDUAL_DELAY=0.5
# Telegram API 读取超时秒数（默认60秒）
API_READ_TIMEOUT=60.0
# Telegram API 写入超时秒数（默认60秒）
API_WRITE_TIMEOUT=60.0
# Telegram API 连接超时秒数（默认30秒）
API_CONNECT_TIMEOUT=30.0
